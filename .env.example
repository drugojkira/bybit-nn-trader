BYBIT_API_KEY=твой_testnet_key
BYBIT_API_SECRET=твой_testnet_secret
TESTNET=true

TELEGRAM_TOKEN=токен_от_BotFather
TELEGRAM_CHAT_ID=твой_chat_id

SYMBOLS=BTCUSDT          # можно добавить через запятую: BTCUSDT,ETHUSDT
TIMEFRAME=5m
INTERVAL_MINUTES=15

RISK_PER_TRADE=0.01
FRACTIONAL_KELLY=0.5     # 0.25-0.75 — чем меньше, тем консервативнее
MAX_DRAWDOWN=0.10
USE_TRAILING=true
TRAILING_STOP_PCT=0.5
SL_ATR_MULTIPLIER=2.0
TP_ATR_MULTIPLIER=4.0