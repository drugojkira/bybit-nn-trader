# === API Биржи ===
# Поддерживаются оба варианта: BINANCE_API_KEY или BYBIT_API_KEY
BINANCE_API_KEY=your_api_key
BINANCE_API_SECRET=your_api_secret
TESTNET=true

# === Telegram ===
TELEGRAM_TOKEN=токен_от_BotFather
TELEGRAM_CHAT_ID=ваш_chat_id

# === Торговля ===
SYMBOLS=BTCUSDT
TIMEFRAME=5m
INTERVAL_MINUTES=15

# === Риск-менеджмент ===
RISK_PER_TRADE=0.01
FRACTIONAL_KELLY=0.5
MAX_DRAWDOWN=0.10
USE_TRAILING=true
TRAILING_STOP_PCT=0.5
SL_ATR_MULTIPLIER=2.0
TP_ATR_MULTIPLIER=4.0
MIN_TRADES_FOR_KELLY=10

# === Обучение модели ===
INITIAL_TRAIN_EPOCHS=10
ONLINE_TRAIN_EPOCHS=3
BATCH_SIZE=64
EARLY_STOPPING_PATIENCE=5
LEARNING_RATE=0.0001
WEIGHT_DECAY=0.00001

# === Мониторинг ===
REPORT_INTERVAL_CANDLES=50
AUTO_DASHBOARD_INTERVAL=200

# === Логирование ===
LOG_FILE=logs/trader.log
LOG_ROTATION=50 MB
LOG_RETENTION=7 days
